# ============================================
# JARVIS CORE — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# Ne JAMAIS commiter .env
# ============================================

# --- MODE D'EXECUTION ---
# production : devices réels (chez Denis)
# mock       : simulateur de devices (jury)
# replay     : rejoue une session enregistrée
JARVIS_MODE=production

# --- TAHOMA (Somfy) ---
# Pour générer le Local API Token :
# 1. Se connecter sur https://www.somfy-connect.com/
# 2. Aller dans "Activer l'API locale"
# 3. Récupérer l'IP de la box (typiquement gateway sur le réseau)
TAHOMA_LOCAL_IP=192.168.1.XX
TAHOMA_LOCAL_PORT=8443
TAHOMA_LOCAL_TOKEN=

# --- FREEBOX ---
# Le freepybox demande un appairage initial (boutton à confirmer sur la Freebox)
# Lors de la 1ère exécution, accepter sur l'écran de la Freebox
FREEBOX_HOST=mafreebox.freebox.fr
FREEBOX_APP_TOKEN=
FREEBOX_APP_ID=jarvis-hackathon

# --- DEVIALET ---
# IP du Phantom visible dans l'app Devialet (paramètres système)
DEVIALET_IP=192.168.1.XX

# --- ANTHROPIC ---
ANTHROPIC_API_KEY=

# --- TTS BACKEND ---
# Choix du moteur TTS : edge (gratuit, défaut) | elevenlabs (Creator tier) | openai (cents)
TTS_BACKEND=edge
# Voix par défaut pour Edge-TTS (Andrew US Multilingual = anglais natif parlant français)
TTS_VOICE_ID=en-US-AndrewMultilingualNeural

# --- ELEVENLABS (optionnel si TTS_BACKEND=elevenlabs) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# --- OPENAI (optionnel si TTS_BACKEND=openai, ou pour STT cloud) ---
OPENAI_API_KEY=
OPENAI_TTS_VOICE=fable

# --- GOOGLE (Calendar + Gmail) ---
# Service Account JSON (path local, pas le contenu)
GOOGLE_CREDENTIALS_PATH=./config/google-credentials.json

# --- LEMLIST ---
LEMLIST_API_KEY=

# --- N8N (orchestrateur cloud Hostinger) ---
N8N_WEBHOOK_BASE_URL=https://creatorweb.fr/webhook/jarvis

# --- CLOUDFLARE TUNNEL ---
# URL publique du tunnel (généré par cloudflared)
JARVIS_PUBLIC_URL=
